# คัดลอกไฟล์นี้เป็น ".env" แล้วใส่ค่าจริงของคุณเอง (.env ถูก gitignore ไว้แล้ว ไม่มีทางขึ้น GitHub)
# ห้ามใส่ค่าจริงในไฟล์นี้ (.env.example) เด็ดขาด — ไฟล์นี้ถูก commit ขึ้น repo เป็นแค่ template

# ค่าจาก Webull OpenAPI Management (https://www.webull.co.th/open-api-management/application)
WEBULL_APP_KEY=your_app_key_here
WEBULL_APP_SECRET=your_app_secret_here

# ไม่บังคับ — ถ้าไม่ใส่ บอทจะเรียก get_account_list() แล้วใช้บัญชีแรกที่เจอให้อัตโนมัติ
# ใส่เองถ้ามีหลายบัญชีแล้วอยากระบุให้ชัด
# WEBULL_ACCOUNT_ID=

# "sandbox" (ค่าเริ่มต้น) = ต่อ Webull test/UAT environment จริง (th-api.uat.webullbroker.com)
#   คนละ endpoint กับเงินจริงเด็ดขาด — ใช้ตอนพัฒนา/ทดสอบเสมอ
# "production" = api.webull.co.th — เงินจริง — เปลี่ยนเป็นค่านี้เฉพาะตอนพร้อมจริงๆ แล้วเท่านั้น
WEBULL_ENV=sandbox

# true = ส่งคำสั่งซื้อขายจริงไปที่ Webull / false (ค่าเริ่มต้น) = แค่ log ว่าจะเทรดอะไร ไม่ส่งคำสั่งจริง
# ต้องตั้งเป็น true ด้วยตัวเองเท่านั้น (บอทจะไม่เปิดโหมดนี้ให้เองเด็ดขาด)
LIVE_TRADING=false

# ── ทดสอบได้ทันทีโดยไม่ต้องรอ App Key ตัวเองอนุมัติ ──
# Webull เผยแพร่ "shared test account" ไว้ในเอกสารทางการ (developer.webull.co.th/apis/docs/sdk)
# สำหรับให้นักพัฒนาทดสอบร่วมกัน — เป็นบัญชีทดสอบสาธารณะ (ไม่ใช่เงินจริง, Webull เตือนว่า
# "orders and positions may change at any time" เพราะทุกคนใช้ร่วมกัน) ใช้ได้เฉพาะตอน
# WEBULL_ENV=sandbox เท่านั้น — คัดลอก 3 บรรทัดด้านล่างไปแทนที่ WEBULL_APP_KEY/SECRET ด้านบน
# เพื่อลองรันบอทได้เลยระหว่างรอ App Key ของตัวเองอนุมัติ:
#   WEBULL_APP_KEY=86d0dac12b1b28de7539f087b2c1dca7
#   WEBULL_APP_SECRET=28dfb45a1be192a04242efd1aeba20f6
#   WEBULL_ACCOUNT_ID=1249711087713001472

# ── Position sizing + circuit breaker (ไม่บังคับ — ค่า default ปลอดภัยอยู่แล้ว) ──
# เงิน (USD) ที่จะใช้ต่อไม้ใหม่ 1 ไม้ (คำนวณจำนวนหุ้นจาก POSITION_SIZE_USD / ราคาปิดวันนั้น)
POSITION_SIZE_USD=500
# ถือได้พร้อมกันสูงสุดกี่ตัว (หยุดเปิดไม้ใหม่ถ้าถือเต็มโควตาแล้ว)
MAX_OPEN_POSITIONS=10
# เปิดไม้ใหม่ได้สูงสุดกี่ไม้ต่อการรัน 1 รอบ (กันบอทซื้อรัวถ้ามีบั๊กในโค้ดสแกน)
MAX_NEW_ENTRIES_PER_RUN=3
