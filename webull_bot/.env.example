# คัดลอกไฟล์นี้เป็น ".env" แล้วใส่ค่าจริงของคุณเอง (.env ถูก gitignore ไว้แล้ว ไม่มีทางขึ้น GitHub)
# ห้ามใส่ค่าจริงในไฟล์นี้ (.env.example) เด็ดขาด — ไฟล์นี้ถูก commit ขึ้น repo เป็นแค่ template

# ค่าจาก Webull OpenAPI Management (https://www.webull.co.th/open-api-management/application)
WEBULL_APP_KEY=your_app_key_here
WEBULL_APP_SECRET=your_app_secret_here

# "sandbox" = โหมดทดสอบ (เงินปลอม ไม่กระทบเงินจริง) — ใช้ตอนพัฒนา/ทดสอบเสมอ
# "production" = เงินจริง — เปลี่ยนเป็นค่านี้เฉพาะตอนพร้อมจริงๆ แล้วเท่านั้น
WEBULL_ENV=sandbox

# true = ส่งคำสั่งซื้อขายจริงไปที่ Webull / false (ค่าเริ่มต้น) = แค่ log ว่าจะเทรดอะไร ไม่ส่งคำสั่งจริง
# ต้องตั้งเป็น true ด้วยตัวเองเท่านั้น (บอทจะไม่เปิดโหมดนี้ให้เองเด็ดขาด)
LIVE_TRADING=false
