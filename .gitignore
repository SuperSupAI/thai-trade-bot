# secrets — ห้ามขึ้น GitHub เด็ดขาด
.env
*.key
*.pem
secrets.*
config.local.*

# python
__pycache__/
*.pyc
.venv/
venv/

# data/*.csv ตอนนี้ track ไว้จริง (อัปเดตวันละครั้งผ่าน GitHub Action, ใช้แทนการยิง yfinance สด)
# ยังกัน *.csv เดี่ยวๆ นอกโฟลเดอร์ data/ ที่ไม่ใช่ของ pipeline นี้ไว้เหมือนเดิม
/*.csv
**/scratch*.csv

# ไฟล์ zip ต้นฉบับข้อมูล 50 ปี (~100MB เกิน limit ของ GitHub) — แปลงเป็น data/archive_*.csv แล้ว
# เก็บไว้เครื่อง local เฉยๆ ไม่ต้องขึ้น repo
set-archive_EOD_1970-LAST.zip

# webull_bot — สถานะการถือครองจริง/paper trading ของแต่ละคน ไม่ควรขึ้น repo ส่วนกลาง
webull_bot/state.json
webull_bot/.env
# SDK ทางการเก็บ 2FA access token ไว้ที่นี่ (default) — เป็น credential ที่ใช้งานได้จริง ห้ามขึ้น repo
webull_bot/conf/
webull_bot/*.log

# ผลลัพธ์การรัน test_*.py / backtest_*.py แบบ ad-hoc — reproducible ได้จากสคริปต์เอง ไม่ต้องขึ้น repo
*_output.txt
*_output_*.txt
webull_bot/backtest_output*.txt
*.pkl

# dr_momentum_bot — credential Settrade Open API (app_id/app_secret/pin) มาจาก env var เท่านั้น
# กันเผื่อใครสร้างไฟล์ .env/config local ไว้ทดสอบเอง ไม่ให้หลุดขึ้น repo
dr_momentum_bot/.env
dr_momentum_bot/config.local.py
dr_momentum_bot/*.log
